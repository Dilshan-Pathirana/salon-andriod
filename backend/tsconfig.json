{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./src",
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": [
    "src/server.ts",
    "src/app.ts",
    "src/config/env.ts",
    "src/config/db.ts",
    "src/models/**/*.ts",
    "src/seed/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

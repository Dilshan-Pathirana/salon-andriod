// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum AppointmentStatus {
  BOOKED
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DayStatus {
  OPEN
  CLOSED
  HOLIDAY
}

model User {
  id               String    @id @default(uuid())
  phoneNumber      String    @unique @map("phone_number") @db.VarChar(10)
  passwordHash     String    @map("password_hash")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  role             Role      @default(CLIENT)
  profileImageUrl  String?   @map("profile_image_url")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  appointments     Appointment[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

model Schedule {
  id               String    @id @default(uuid())
  date             DateTime  @unique @db.Date
  status           DayStatus @default(OPEN)
  startTime        String    @map("start_time") @db.VarChar(5)  // "09:00"
  endTime          String    @map("end_time") @db.VarChar(5)    // "18:00"
  slotDurationMins Int       @default(20) @map("slot_duration_mins")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  appointments     Appointment[]

  @@map("schedules")
}

model Appointment {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  scheduleId     String            @map("schedule_id")
  date           DateTime          @db.Date
  timeSlot       String            @map("time_slot") @db.VarChar(5)  // "09:00"
  queuePosition  Int               @map("queue_position")
  status         AppointmentStatus @default(BOOKED)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule       Schedule          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([date, timeSlot], name: "unique_date_timeslot")
  @@index([userId])
  @@index([date])
  @@index([date, status])
  @@index([scheduleId])
  @@map("appointments")
}

model Session {
  id        String    @id @default(uuid())
  date      DateTime  @unique @db.Date
  isClosed  Boolean   @default(false) @map("is_closed")
  openedAt  DateTime  @default(now()) @map("opened_at")
  closedAt  DateTime? @map("closed_at")

  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

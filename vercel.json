{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm --prefix web run build",
        "installCommand": "npm install",
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api",
      "dest": "/backend/api/index"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

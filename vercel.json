{
  "version": 2,
  "installCommand": "npm install && npm --prefix backend install && npm --prefix web install --include=dev",
  "buildCommand": "npm --prefix web run build",
  "outputDirectory": "web/dist",
  "routes": [
    {
      "src": "/api",
      "dest": "/api/[...all].ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

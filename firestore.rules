rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Users ──
    match /users/{userId} {
      allow read: if isSignedIn();
      // Writes handled by Cloud Functions
      allow write: if false;
    }

    // ── Services (public read) ──
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Gallery (public read) ──
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Reviews (public read) ──
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Business Info (public read) ──
    match /businessInfo/{key} {
      allow read: if true;
      allow write: if false;
    }

    // ── Schedules (authenticated read) ──
    match /schedules/{date} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Appointments (authenticated read own or admin reads all) ──
    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Sessions (authenticated read) ──
    match /sessions/{date} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Helper collections (no direct client access) ──
    match /slotLocks/{lockId} {
      allow read, write: if false;
    }

    match /userDayLocks/{lockId} {
      allow read, write: if false;
    }

    match /queueCounters/{date} {
      allow read, write: if false;
    }
  }
}
